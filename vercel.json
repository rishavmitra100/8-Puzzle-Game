{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/manifest.json",
      "destination": "/public/manifest.json"
    },
    {
      "source": "/sw.js",
      "destination": "/public/sw.js"
    },
    {
      "source": "/logo.ico",
      "destination": "/public/logo.ico"
    },
    {
      "source": "/logo (1).png",
      "destination": "/public/logo (1).png"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}